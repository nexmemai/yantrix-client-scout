# Compose
COMPOSE_PROJECT_NAME=yantrix-client-scout
COMPOSE_PROFILES=
USE_LOCAL_POSTGRES=false
ENABLE_N8N=false
ENABLE_SCRAPY=false

# Host port bindings. Defaults are localhost-only for safer single-VM production.
# Use API_HOST_PORT=0.0.0.0:8000 only for temporary public API debugging.
API_HOST_PORT=127.0.0.1:8000
DASHBOARD_HOST_PORT=127.0.0.1:3000
GMAPS_HOST_PORT=127.0.0.1:8080
POSTGRES_HOST_PORT=127.0.0.1:5432
API_PORT=8000
DASHBOARD_PORT=3000
DASHBOARD_CONTAINER_PORT=8080
POSTGRES_PORT=5432
N8N_PORT=5678

# App
APP_NAME=Yantrix Client Scout API
APP_VERSION=0.1.0
DEBUG=false
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000
# Dashboard production uses same-origin /api via Nginx. Set only for local Vite dev.
VITE_API_BASE_URL=

# Database
# For local Postgres set USE_LOCAL_POSTGRES=true and DB_HOST=db.
# For Supabase/external Postgres set USE_LOCAL_POSTGRES=false and use the host/user/password from the provider.
DB_HOST=db
DB_PORT=5432
DB_NAME=clientscout
DB_USER=scout
DB_PASSWORD=change-me
POSTGRES_IMAGE=postgres:16-alpine
# Postgres container env (must match DB_* values above)
POSTGRES_DB=clientscout
POSTGRES_USER=scout
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db

# Scrapers
GMAPS_IMAGE=gosom/google-maps-scraper:latest
GMAPS_SCRAPER_URL=http://gmaps-scraper:8080
GMAPS_CONCURRENCY=2
SCRAPER_CONCURRENCY=2
SCRAPY_WORKER_IMAGE=yantrix/client-scout-scrapy:latest
SCRAPY_WORKER_COMMAND=scrapy crawl justdial
SCRAPY_PROJECT=client_scout_scrapers
SCRAPY_SPIDER=justdial
SCRAPY_LOG_LEVEL=INFO
JUSTDIAL_ENABLED=false

# LLM Provider — options: nvidia, groq, openai
LLM_PROVIDER=nvidia
LLM_MODEL_NAME=meta/llama-3.3-70b-instruct
LLM_API_KEY=
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

# NVIDIA NIM (used when LLM_PROVIDER=nvidia)
NVIDIA_NIM_API_KEY=nvapi-your-key-here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# Groq (used when LLM_PROVIDER=groq — free tier available)
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional Google PageSpeed
PSI_API_KEY=

# CRM Export
HUBSPOT_ACCESS_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
LEAD_WEBHOOK_DEFAULT_URL=
RUN_SCOUT_HOURLY_LIMIT=10

# Worker tuning
AUDIT_CONCURRENCY=3
WORKER_CONCURRENCY=4

# Redis / ARQ queue
REDIS_IMAGE=redis:7-alpine
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=127.0.0.1:6379
REDIS_MAXMEMORY=256mb
WORKER_MAX_JOBS=8
WORKER_JOB_TIMEOUT_SECONDS=1800
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_STALE_JOB_THRESHOLD_SECONDS=300

# Snapshot storage
SNAPSHOT_BACKEND=local
SNAPSHOT_DIR=/app/snapshots
API_SNAPSHOT_VOLUME_PATH=/app/snapshots

# n8n
N8N_IMAGE=n8nio/n8n:latest
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-me-before-production
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
GENERIC_TIMEZONE=Asia/Kolkata


# Phase 4: Autonomous Outreach
# When OUTREACH_DRY_RUN=true (default) every send is logged but nothing is
# actually mailed or pushed to WhatsApp. Flip to false ONLY after you set
# real SMTP and WhatsApp Cloud API credentials below.
OUTREACH_DRY_RUN=true
# Default for the run-scout `auto_send_enabled` request flag. The dashboard
# always sends an explicit value, but other clients (curl, n8n) get this
# value if they omit the field. Keep false in production.
OUTREACH_AUTOSEND_DEFAULT=false

# Email (SMTP). Leave blank to use the dry-run sender.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=
SMTP_TIMEOUT_SECONDS=20

# WhatsApp (Meta WhatsApp Business Cloud API). Leave blank to use the
# dry-run sender. The phone number id and access token come from the
# WhatsApp Business Platform console for the sending number.
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TIMEOUT_SECONDS=20
