# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Yantrix Client Scout API"
APP_VERSION="0.1.0"
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated allowed CORS origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clientscout
DB_USER=scout
DB_PASSWORD=changeme

# ── Google Maps Scraper sidecar ───────────────────────────────────────────────
GMAPS_SCRAPER_URL=http://gmaps-scraper:8080

# ── LLM Providers ────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# Get your free key at: https://build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-replace_me
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# ── Google PageSpeed Insights (optional) ─────────────────────────────────────
# Leave empty to skip PSI checks (still does Playwright-based audit)
PSI_API_KEY=

# ── CRM Export (optional) ────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
LEAD_WEBHOOK_DEFAULT_URL=
RUN_SCOUT_HOURLY_LIMIT=10

# ── Worker tuning ─────────────────────────────────────────────────────────────
# Max parallel Playwright browsers (keep ≤4 on GCP e2-medium to avoid OOM)
AUDIT_CONCURRENCY=3
SCRAPER_CONCURRENCY=2

# ── HTML Snapshot Storage ─────────────────────────────────────────────────────
# "local" saves to disk (SNAPSHOT_DIR). "s3" uploads to S3/MinIO.
SNAPSHOT_BACKEND=local
SNAPSHOT_DIR=./snapshots

# For S3 / MinIO backend:
# S3_ENDPOINT_URL=http://minio:9000    # leave blank for AWS S3
# S3_BUCKET=client-scout-snapshots
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=ap-south-1

# ── Feature flags ─────────────────────────────────────────────────────────────
JUSTDIAL_ENABLED=false
